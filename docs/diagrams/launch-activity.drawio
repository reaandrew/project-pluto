<mxfile host="app.diagrams.net" type="device">
  <diagram name="How it works">
    <mxGraphModel dx="1200" dy="1600" grid="0" gridSize="10" page="1" pageWidth="950" pageHeight="2260" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="How it works — from setting up to seeing results" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="16" width="880" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="Who does what&#10;● You (using the admin screens)     ● The system, automatically     ● Email &amp; website hosting     ◆ A decision" style="text;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;strokeColor=#999999;fillColor=#FBFBFB;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="48" width="380" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="n0" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="330" y="60" width="30" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="n1" value="You choose an industry to target and set&#10;the ground rules: what makes a good lead,&#10;the website style, and the email tone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="230" y="120" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="n2" value="The search for businesses begins —&#10;automatically every hour, or right away&#10;when you click &quot;Run discovery now&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="220" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="n3" value="It finds businesses from public directories&#10;and any lists you upload — skipping ones&#10;already seen, and being gentle on websites" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="320" width="300" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="d1" value="A new business is added to the list" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="330" width="210" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n4" value="It looks at the business's current&#10;website and takes a screenshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="420" width="300" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="n5" value="The AI checks the business against&#10;your &quot;good lead&quot; rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="515" width="300" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="dec1" value="Good&#10;enough&#10;lead?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="320" y="600" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="rej1" value="Not a fit — set aside" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="620" width="210" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n6" value="The AI writes a plan for a&#10;better website for them" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="710" width="300" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="n7" value="The AI builds a private preview&#10;of the new website" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="790" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d2" value="Preview ready, waiting for your review" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="800" width="210" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n8" value="You open the review queue and look at&#10;the plan and the preview website" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="230" y="885" width="300" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="dec2" value="Your&#10;decision" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="320" y="975" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="rej2" value="Reject — drop this one" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="995" width="210" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n9" value="The AI drafts an outreach email&#10;in your chosen tone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="230" y="1090" width="300" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="n10" value="You read the email and approve it" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="230" y="1190" width="300" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="n11" value="The email is sent to the business&#10;(with spend limits, and never twice)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="230" y="1280" width="300" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="n12" value="If they reply, the AI sorts the reply&#10;and it appears in your Replies inbox" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
          <mxGeometry x="230" y="1375" width="300" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="n13" value="You mark it as won when they&#10;become a customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="230" y="1470" width="300" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="fb" value="You leave feedback. Each week the system&#10;suggests improvements to the rules, style&#10;and tone — you apply them with one click" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="215" y="1560" width="330" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="n14" value="Your dashboard updates every hour:&#10;how many businesses at each stage, spend,&#10;and reply rates&#10;◀ this is where you watch it all happen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="215" y="1665" width="330" height="75" as="geometry"/>
        </mxCell>

        <mxCell id="nEnd" value="" style="ellipse;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="365" y="1780" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="nEndDot" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="371" y="1786" width="18" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="e0" style="endArrow=block;html=1;" edge="1" parent="1" source="n0" target="n1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed1" style="endArrow=open;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="n3" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="1" source="n5" target="dec1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="no" style="endArrow=block;html=1;" edge="1" parent="1" source="dec1" target="rej1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="yes" style="endArrow=block;html=1;" edge="1" parent="1" source="dec1" target="n6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="endArrow=block;html=1;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed2" style="endArrow=open;html=1;dashed=1;strokeColor=#D79B00;" edge="1" parent="1" source="n7" target="d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="endArrow=block;html=1;" edge="1" parent="1" source="n7" target="n8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="endArrow=block;html=1;" edge="1" parent="1" source="n8" target="dec2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="reject" style="endArrow=block;html=1;" edge="1" parent="1" source="dec2" target="rej2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" value="approve" style="endArrow=block;html=1;" edge="1" parent="1" source="dec2" target="n9"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" value="ask for a new version" style="endArrow=block;html=1;dashed=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="dec2" target="n6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="170" y="1015"/><mxPoint x="170" y="735"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e14" style="endArrow=block;html=1;" edge="1" parent="1" source="n9" target="n10"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" style="endArrow=block;html=1;" edge="1" parent="1" source="n10" target="n11"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" style="endArrow=block;html=1;" edge="1" parent="1" source="n11" target="n12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" style="endArrow=block;html=1;" edge="1" parent="1" source="n12" target="n13"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e18" style="endArrow=block;html=1;" edge="1" parent="1" source="n13" target="fb"><mxGeometry relative="1" as="geometry"/></mxCell>
