# .ralphrc - Ralph project configuration for ai-website-agency
# Documentation: https://github.com/frankbria/ralph-claude-code

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================

PROJECT_NAME="${PROJECT_NAME:-ai-website-agency}"
PROJECT_TYPE="${PROJECT_TYPE:-typescript}"

# =============================================================================
# LOOP SETTINGS
# =============================================================================

MAX_CALLS_PER_HOUR=60
CLAUDE_TIMEOUT_MINUTES=20
CLAUDE_OUTPUT_FORMAT="json"

# =============================================================================
# TOOL PERMISSIONS
# =============================================================================

# Generous allowlist for autonomous operation. Excludes only the genuinely
# destructive / human-only commands: aws-vault, terraform apply, terraform
# destroy, sudo, ssh. The destructive-AWS hook in .claude/settings.json
# blocks `terraform destroy` against protected envs and S3 prod bucket
# deletion as a second layer.
ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,\
Bash(git *),\
Bash(grep *),Bash(find *),Bash(ls *),Bash(cat *),Bash(head *),Bash(tail *),Bash(wc *),Bash(file *),Bash(stat *),Bash(which *),Bash(whoami),Bash(pwd),Bash(env),Bash(printenv *),Bash(date *),Bash(diff *),\
Bash(jq *),Bash(yq *),Bash(awk *),Bash(sed *),Bash(cut *),Bash(sort *),Bash(uniq *),Bash(tr *),Bash(xargs *),Bash(tee *),\
Bash(mkdir *),Bash(cp *),Bash(mv *),Bash(touch *),Bash(chmod *),Bash(rm *),Bash(ln *),\
Bash(echo *),Bash(printf *),Bash(test *),Bash(true),Bash(false),\
Bash(curl *),Bash(wget *),Bash(nc *),\
Bash(gh *),\
Bash(make *),Bash(go *),Bash(gofmt *),Bash(goimports *),\
Bash(pnpm *),Bash(npm *),Bash(npx *),Bash(node *),Bash(yarn *),Bash(tsc *),Bash(vitest *),Bash(jest *),Bash(playwright *),\
Bash(cdk *),Bash(wrangler *),\
Bash(terraform plan *),Bash(terraform fmt *),Bash(terraform validate *),Bash(terraform init *),Bash(terraform show *),Bash(terraform output *),Bash(terraform state list *),Bash(terraform state show *),Bash(terraform providers *),Bash(terraform graph *),Bash(terraform version),Bash(tflint *),Bash(tfsec *),Bash(checkov *),\
Bash(docker compose up *),Bash(docker compose down *),Bash(docker compose logs *),Bash(docker compose ps *),Bash(docker compose exec *),Bash(docker compose run *),Bash(docker compose build *),\
Bash(bash *),Bash(sh *),Bash(./scripts/* *),Bash(./scripts/*),Bash(./bin/* *),Bash(./bin/*),Bash(./Makefile *)"

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# =============================================================================
# TASK SOURCES
# =============================================================================

TASK_SOURCES="local"

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================

CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_COOLDOWN_MINUTES=30
CB_AUTO_RESET=false

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

CLAUDE_AUTO_UPDATE=true
CLAUDE_MIN_VERSION="2.0.76"
RALPH_VERBOSE=false
